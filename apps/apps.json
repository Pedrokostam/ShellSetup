{
  "$schema": "./schema.json",
  "defaults": {
    "windows": {
      "default": "winget",
      "installers": [
        {
          "name": "winget",
          "command": "winget install --id $name --accept-package-agreements -e --scope user -h --source winget",
          "elevated": false
        },
        { "name": "scoop", "command": "scoop install $name", "elevated": false }
      ]
    },
    "debian": {
      "installers": [
        { "name": "apt", "command": "apt install $name -y", "elevated": true }
      ]
    }
  },
  "apps": [
    {
      "name": "git",
      "debian": true,
      "windows": {
        "name": "Git.Git",
        "elevated": true
      }
    },
    {
      "name": "Notepad++",
      "debian": false,
      "windows": {
        "name": "Notepad++.Notepad++"
      }
    },
    {
      "name": "flatpak",
      "windows": false,
      "debian": true
    },
    {
      "name": "micro",
      "debian": true,
      "windows": {
        "name": "zyedidia.micro"
      }
    },
    {
      "name": "oh-my-posh",
      "windows": {
        "name": "JanDeDobbeleer.OhMyPosh"
      },
      "debian": {
        "command": "curl -s https://ohmyposh.dev/install.sh | bash -s",
        "elevated": false
      }
    },
    {
      "name": "Firefox",
      "debian": false,
      "windows": {
        "name": "Mozilla.Firefox"
      }
    },
    {
      "name": "PowerShell",
      "windows": {
        "name": "Microsoft.PowerShell"
      },
      "debian": false
    },
    {
      "name": "scoop",
      "windows": {
        "elevated": false,
        "command": "Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser; Invoke-RestMethod -Uri https://get.scoop.sh | Invoke-Expression"
      },
      "debian": false
    }
  ]
}
