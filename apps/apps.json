{
  "defaults": {
    "windows": {
      "winget": "winget --id $name --accept-package-agreements -e --scope user",
      "scoop": "scoop install $name",
      "default": "winget"
    },
    "debian": {
      "apt": "sudo apt install $name -y"
    }
  },
  "apps": [
    {
      "name": "git",
      "debian": true,
      "windows": {
        "name": "git.git"
      }
    },
    {
      "name": "notepad++",
      "debian": false,
      "windows": {
        "name": "notepad++.notepad++"
      }
    },
    {
      "name": "scoop",
      "windows": {
        "command": "Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser; Invoke-RestMethod -Uri https://get.scoop.sh | Invoke-Expression"
      },
      "debian": false
    },
     {
      "name": "flatpak",
      "windows": false,
      "debian": true
    },
    {
      "name": "micro",
      "debian": true,
      "windows": {
        "name": "zyedidia.micro"
      }
    },
    {
      "name": "oh-my-posh",
      "windows": {
        "name": "JanDeDobbeleer.OhMyPosh"
      },
      "debian": {
        "command": "curl -s https://ohmyposh.dev/install.sh | bash -s"
      }
    },
    {
      "name": "Firefox",
      "debian": {
        "command":"flatpak install flathub org.mozilla.firefox"
      },
      "windows": {
        "name": "Mozilla.Firefox"
      }
    },
    {
      "name": "PowerShell",
      "windows": {
        "name": "Microsoft.PowerShell"
      },
      "debian": false
    }
  ]
}