{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "async": true,
  "console_title_template": "{{ .Folder }} - {{ .Shell }}{{if .WSL }} (WSL){{ end }}",
  "var": {
    "head_last_char": 6,
    "head_length": 28
  },
  "palette": {
    "lightBlack": "#20232a",
    "lightBlue": "#61AFEF",
    "lightCyan": "#56B6C2",
    "lightGreen": "#98C379",
    "lightMagenta": "#C678DD",
    "lightRed": "#E06C75",
    "lightWhite": "#DCDFE4",
    "lightYellow": "#E5C07B",
    "black": "#282C34",
    "blue": "#2490e9",
    "cyan": "#3b99a5",
    "green": "#77af4e",
    "magenta": "#af42cf",
    "red": "#da515b",
    "white": "#DCDFE4",
    "yellow": "#d9a440",
    "background": "transparent",
    "os": "p:lightBlue",
    "path": "p:lightGreen",
    "git": "p:lightCyan",
    "python": "p:yellow",
    "executiontime": "p:lightRed",
    "time": "p:lightMagenta",
    "shell": "p:green",
    "session": "p:red",
    "session_sep": "p:lightCyan"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "options": {},
          "style": "powerline",
          "template": "{{ .Icon }} {{ .HostName }}{{ if .WSL }} (WSL){{ end }} ",
          "background": "p:background",
          "foreground": "p:os"
        },
        {
          "type": "path",
          "options": {
            "folder_icon": "...",
            "folder_separator_icon": "<darkGray>/</>",
            "mapped_locations": {
              "re:(.*/FLACBAZA)": " ",
              "~/Downloads": " "
            },
            "max_depth": 3,
            "max_width": 60,
            "style": "powerlevel"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "background": "p:background",
          "foreground": "p:path"
        },
        {
          "type": "git",
          "options": {
            "fetch_status": false
          },
          "style": "plain",
          "template": "{{ $prefix := regexFind \"^.*?/\" .HEAD}}{{ $suffix := trimPrefix $prefix .HEAD}}{{ $prefix := replace \"/\" \"<d>/</d>\" $prefix }}{{ $suffix := regexReplaceAll \"^(.{10})(.*)(.{10})$\" $suffix \"$1~$3\" }}{{ $suffix := regexReplaceAll \"[\\\\s-_~/]*~[\\\\s-_~/]*\" $suffix \"~\" }}{{ print $prefix $suffix }}",
          "background": "p:background",
          "foreground": "p:git"
        },
        {
          "style": "plain",
          "template": " {{ .Major }}.{{ .Minor }} ",
          "type": "python",
          "background": "p:background",
          "foreground": "p:python"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "options": {
            "always_enabled": true,
            "style": "austin"
          },
          "style": "plain",
          "template": " {{ .FormattedMs }}",
          "type": "executiontime",
          "background": "p:background",
          "foreground": "p:executiontime"
        },
        {
          "options": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": " {{ .CurrentDate | date .Format }}",
          "type": "time",
          "background": "p:background",
          "foreground": "p:time"
        },
        {
          "type": "shell",
          "style": "plain",
          "template": " {{ .Name }}",
          "background": "p:background",
          "foreground": "p:shell"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "style": "plain",
          "template": "{{ if .Root }}{{else}}{{end}}<b>{{ .UserName }}<p:session_sep>></></b>",
          "type": "session",
          "background": "p:background",
          "foreground": "p:session"
        }
      ],
      "newline": true
    }
  ]
}
