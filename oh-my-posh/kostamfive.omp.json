{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "async": true,
  "console_title_template": "{{ .Folder }} - {{ .Shell }}{{if .WSL }} (WSL){{ end }}",
  "var": {
    "head_last_char": 6,
    "head_length": 28
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "os",
          "properties": {
            "windows": ""
          },
          "style": "powerline",
          "template": "{{ .Icon }} {{ .HostName }}{{ if .WSL }} (WSL){{ end }} ",
          "foreground": "lightBlue"
        },
        {
          "type": "path",
          "properties": {
            "folder_icon": "...",
            "folder_separator_icon": "<darkGray>/</>",
            "mapped_locations": {
              "re:(.*/FLACBAZA)": " ",
              "~/Downloads": " "
            },
            "max_depth": 3,
            "max_width": 60,
            "style": "powerlevel"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "foreground": "lightGreen"
        },
        {
          "type": "git",
          "properties": {
            "branch_max_length": 100,
            "fetch_stash_count": false,
            "fetch_status": false
          },
          "style": "plain",
          "template": "{{ $front:=sub (sub .Var.head_length .Var.head_last_char) 1 }}{{ $branch := .HEAD }}{{$prefix := regexFind \"^(.+)/\" $branch}}{{ $rest := trimPrefix $prefix $branch}}{{ $len:= len $rest }}{{$prefix := regexReplaceAll \"release/\" $prefix \"𝌚 /\" }}{{$prefix := regexReplaceAll \"bug.*/\" $prefix \" /\" }}{{$prefix := regexReplaceAll \"hot.*/\" $prefix \"🔥/\" }}{{$prefix}}{{ if gt $len (.Var.head_length) }} {{ trunc $front $rest }}…{{ trunc (mul -1 .Var.head_last_char) $rest }}{{ else }}{{ $rest }}{{ end }} ",
          "foreground": "cyan",
          "mapped_branches": {
            "feat*/*": "𝌚",
            "release/2025-2": "⚙",
            "bug*/*": "🐛",
            "hot*/*": "🔥"
          }
        },
        {
          "style": "plain",
          "template": " {{ .Major }}.{{ .Minor }} ",
          "foreground": "yellow",
          "type": "python"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "properties": {
            "always_enabled": true,
            "style": "austin"
          },
          "style": "plain",
          "template": " {{ .FormattedMs }}",
          "foreground": "red",
          "type": "executiontime"
        },
        {
          "properties": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": " {{ .CurrentDate | date .Format }}",
          "foreground": "lightMagenta",
          "type": "time"
        },
        {
          "type": "shell",
          "style": "plain",
          "template": " {{ .Name }}",
          "foreground": "green"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "style": "plain",
          "template": "{{ if .Root }}{{else}}{{end}}<b><lightRed>{{ .UserName }}</>></b>",
          "foreground": "default",
          "type": "session"
        }
      ],
      "newline": true
    }
  ]
}
